{
  "name": "drivestore",
  "description": "A tiny, typed path-based file store backed by Google Drive's appDataFolder — store text or binary, bring any state or database layer.",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vitest run && tsup",
    "build:notest": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "storage",
    "database"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "somewhatmay",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "tsup": "^8.5.1",
    "typescript": "5.7",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
