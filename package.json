{
  "name": "drivestore",
  "description": "Convenient IO to store your client data in their personal cloud storage.",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vitest run && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "storage",
    "database"
  ],
  "author": "somewhatmay",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.7",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
